{
  "require": {
    "phpmailer/phpmailer": "^6.9",
    "pay-now/paynow-php-sdk": "^3.0",
    "guzzlehttp/guzzle": "^7.11",
    "guzzlehttp/psr7": "^2.11"
  },
  "require-dev": {
    "phpunit/phpunit": "^11"
  },
  "autoload": {
    "psr-4": {
